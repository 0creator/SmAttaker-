# ─────────────────────────────────────────────────────────
# SmAttaker Trading System — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy to .env and fill in your values

# ── App ──────────────────────────────────────────────────
APP_NAME=SmAttaker
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Database (Supabase PostgreSQL) ────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis (Upstash) ───────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=SmAttakerBot
TELEGRAM_ADMIN_CHAT_ID=  # your personal telegram chat ID for admin alerts

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAIL=amanossama@gmail.com
ADMIN_TELEGRAM_ID=  # your telegram user ID

# ── NOWPayments (Crypto Payments) ─────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# ── Strategy Engine ───────────────────────────────────
CRYPTO_TIMEFRAME=30m
CRYPTO_FETCH_LIMIT=1000
CRYPTO_MIN_BARS=500
CRYPTO_STRATEGY_ENABLED=true
GOLD_FOREX_STRATEGY_ENABLED=true

# ── Subscription Defaults ─────────────────────────────────
SUBSCRIPTION_PRICE_USD=99
TRIAL_DAYS=3
DEFAULT_LANGUAGE=en

# ── Trading ───────────────────────────────────────────────
MAX_DAILY_SIGNALS=50
SIGNAL_EXPIRY_MINUTES=60
DEFAULT_LEVERAGE=10
MAX_LEVERAGE=125

# ── Market Data (Gold/Forex/Stocks) ───────────────────────
# Official, documented API — the reliable fix for Yahoo Finance blocking
# cloud/datacenter IPs (yfinance is an unofficial scraper and gets
# blocked). Free tier: https://twelvedata.com/pricing (800 req/day).
# Leave blank to fall back to yfinance (may be blocked on Render).
TWELVE_DATA_API_KEY=

# ── Manual Crypto Wallets (optional — leave blank to disable) ─
# ⚠️ Do NOT copy an example address from anywhere, and NEVER put the
# same address in two different network fields unless you've verified
# it's genuinely valid on both (TRC20 and ERC20/BEP20 are NEVER the
# same format — don't even try). Each address is validated against its
# network's real format at runtime; anything that doesn't match is
# hidden from users automatically rather than risking a lost payment.
# Leave any of these blank to simply not offer that network.
USDT_TRC20_ADDRESS=
USDT_ERC20_ADDRESS=
USDT_BEP20_ADDRESS=
BTC_WALLET_ADDRESS=

# ── Internal Service Auth ─────────────────────────────────
# Required for the bot backend to call /api/auth/login on behalf of a
# user it already verified via Telegram's own API. Generate a long
# random string and keep it secret — never expose it to end users.
INTERNAL_API_KEY=

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list, e.g. https://app.example.com,https://admin.example.com
# Leave blank only for early local development.
CORS_ALLOWED_ORIGINS=

# ── Strategy Scheduler ─────────────────────────────────────
STRATEGY_RUN_INTERVAL_MINUTES=15

# ── Render / Deployment ───────────────────────────────────
PORT=8000
RENDER_EXTERNAL_URL=https://your-app.onrender.com
WEBHOOK_URL=https://your-app.onrender.com/api/webhooks
